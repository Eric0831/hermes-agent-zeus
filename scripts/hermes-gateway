#!/usr/bin/env python3
"""Deprecated wrapper for the unified gateway service flow.

The only supported runtime entrypoint is:
    python -m hermes_cli.main gateway <subcommand>

Keep this file as a thin compatibility shim so existing operators do not
accidentally start a second, divergent service manager path after updates.
"""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path


PROJECT_DIR = Path(__file__).resolve().parents[1]

_ALIASES = {
    "run": ["run", "--replace"],
    "start": ["start"],
    "stop": ["stop"],
    "restart": ["restart"],
    "status": ["status"],
    "install": ["install"],
    "uninstall": ["uninstall"],
    "logs": ["logs"],
}


def main() -> int:
    argv = sys.argv[1:] or ["run"]
    command = argv[0]
    forwarded = _ALIASES.get(command, argv)
    print(
        "scripts/hermes-gateway is deprecated. "
        "Use the official entrypoint: python -m hermes_cli.main gateway ...",
        file=sys.stderr,
    )
    env = os.environ.copy()
    env.setdefault("PYTHONPATH", str(PROJECT_DIR))
    result = subprocess.run(
        [sys.executable, "-m", "hermes_cli.main", "gateway", *forwarded],
        cwd=str(PROJECT_DIR),
        env=env,
    )
    return int(result.returncode)


if __name__ == "__main__":
    raise SystemExit(main())
