[Unit]
Description=Hermes Federation Audit Report (all 6 gateways)
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/home/testai/.hermes/hermes-agent
Environment="PATH=/home/testai/.hermes/hermes-agent/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/testai/.hermes/hermes-agent/venv/bin/python /home/testai/.hermes/hermes-agent/scripts/hermes_audit_report.py --snapshot --diff
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
