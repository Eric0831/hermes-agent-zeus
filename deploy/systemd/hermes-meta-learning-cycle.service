[Unit]
Description=Hermes Federation Meta-Learning Cycle (all 6 gateways)
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/home/testai/.hermes/hermes-agent
Environment="PATH=/home/testai/.hermes/hermes-agent/venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/home/testai/.hermes/hermes-agent/venv/bin/python /home/testai/.hermes/hermes-agent/scripts/hermes_meta_learning_cycle.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
